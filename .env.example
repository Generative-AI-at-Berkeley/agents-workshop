# LLM providers
GROQ_API_KEY=

# Tools
FIRECRAWL_API_KEY=

# Langfuse (local self-hosted). Keys below match LANGFUSE_INIT_* in docker-compose.yml —
# they're auto-seeded on first boot, no manual UI setup needed.
LANGFUSE_PUBLIC_KEY=pk-lf-workshop-local-dev
LANGFUSE_SECRET_KEY=sk-lf-workshop-local-dev
LANGFUSE_HOST=http://localhost:3200
